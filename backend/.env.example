# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/m4movers
# If your Postgres provider requires SSL (e.g. Render, Railway, Neon), set to true
DATABASE_SSL=false

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
RESET_TOKEN_SECRET=change-this-to-a-different-long-random-string
RESET_TOKEN_EXPIRES_IN=15m

# Verification / reset codes
OTP_EXPIRES_MINUTES=10

# SMTP (used to send verification codes, password reset codes, and
# to forward Contact/Quote and WhatsApp lead notifications to the admin)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="M4 Movers" <no-reply@m4movers.com>

# Admin / company info (single source of truth, also served to the frontend)
ADMIN_NOTIFY_EMAIL=info@m4movers.com
COMPANY_EMAIL=info@m4movers.com
COMPANY_PHONE=+971 56 184 2818
COMPANY_WHATSAPP=971561842818
COMPANY_ADDRESS=Al Marsa Street, Dubai, UAE
COMPANY_LAT=25.0783
COMPANY_LNG=55.1436

# Seed admin account (created by `npm run migrate`)
ADMIN_SEED_NAME=M4 Movers Admin
ADMIN_SEED_EMAIL=admin@m4movers.com
ADMIN_SEED_PASSWORD=Admin@12345
